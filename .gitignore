# Pixi, direnv, and Python caches
.pixi/
.direnv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage

# ROS 2 / colcon artifacts
build/
install/
log/
compile_commands.json

# Local virtual environments and environment overrides
.venv/
venv/
.env
.env.*
!.env.example

# Machine-local CycloneDDS instances live under .config/ next to the
# checked-in template. Track only cyclonedds_template.xml; ignore filled-in
# copies (e.g. cyclonedds_hik_host_192.168.10.100.xml).
.config/*
!.config/
!.config/cyclonedds_template.xml
!.config/cyclonedds_default.xml

# Runtime data and machine-local state
.cloudxr/*
!.cloudxr/.gitkeep
data/
calibrations/
metrics/
MUJOCO_LOG.TXT

# Editor and operating-system noise
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db

# Reference checkouts are development inputs, not runtime source packages.
ref/

# ROS package checkouts under src/ are managed as independent repositories.
# The workspace repository must not vendor or track anything below this path.
/src/
