# Activate a locked Physical AI Runtime Pixi environment.
# Dependency updates are explicit; entering the directory never re-solves.
#
# Selection (first match):
#   1. PIXI_ENV=cpu|default     — explicit override
#   2. .pixi/environment        — written by `pixi run [-e …] setup`
#   3. only one of default/cpu installed under .pixi/envs/
#   4. else default             — GPU stack
#
# Workspace paths (CLOUDXR_DIR on GPU, WORKSPACE_ROOT, RMW_IMPLEMENTATION)
# come from pixi.toml activation via shell-hook — do not re-export them here.
_pixi_env="${PIXI_ENV:-}"
if [ -z "$_pixi_env" ] && [ -f .pixi/environment ]; then
  _pixi_env="$(tr -d '[:space:]' < .pixi/environment)"
fi
if [ -z "$_pixi_env" ]; then
  if [ -d .pixi/envs/default ] && [ ! -d .pixi/envs/cpu ]; then
    _pixi_env=default
  elif [ -d .pixi/envs/cpu ] && [ ! -d .pixi/envs/default ]; then
    _pixi_env=cpu
  else
    _pixi_env=default
  fi
fi
export PIXI_FROZEN=true
eval "$(pixi shell-hook --frozen -e "$_pixi_env")"
if [ "$_pixi_env" = cpu ]; then
  unset CLOUDXR_DIR
fi
unset _pixi_env

# Source the colcon overlay after at least one successful build.
if [ -f install/setup.bash ]; then
  source install/setup.bash
fi
