# Activate the single locked Physical AI Runtime environment.
# Dependency updates are explicit; entering the directory never re-solves.
# Workspace paths (CLOUDXR_DIR, WORKSPACE_ROOT, RMW_IMPLEMENTATION) come from
# pixi.toml [activation.env] via shell-hook — do not re-export them here.
export PIXI_FROZEN=true
eval "$(pixi shell-hook --frozen)"

# Source the colcon overlay after at least one successful build.
if [ -f install/setup.bash ]; then
  source install/setup.bash
fi
